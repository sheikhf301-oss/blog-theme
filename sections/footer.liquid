<footer class="site-footer">
  <div class="page-width">
    <div class="footer-grid">

      <div class="footer__brand">
        <a href="/" class="footer__logo">{{ section.settings.blog_name | default: shop.name }}</a>
        <p class="footer__tagline">{{ section.settings.tagline | default: 'Stories worth reading.' }}</p>
        <div class="footer__social">
          {% if section.settings.instagram != blank %}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram">Instagram</a>
          {% endif %}
          {% if section.settings.twitter != blank %}
            <a href="{{ section.settings.twitter }}" target="_blank" rel="noopener" aria-label="Twitter">Twitter</a>
          {% endif %}
          {% if section.settings.pinterest != blank %}
            <a href="{{ section.settings.pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">Pinterest</a>
          {% endif %}
        </div>
      </div>

      <div class="footer__col">
        <p class="footer__col-title">Navigate</p>
        <ul class="footer__links">
          <li><a href="/">Home</a></li>
          <li><a href="/blogs/news">All Articles</a></li>
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__col-title">Topics</p>
        <ul class="footer__links">
          {% for link in linklists['footer-topics'].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% else %}
            <li><a href="/blogs/news/tagged/stories">Stories</a></li>
            <li><a href="/blogs/news/tagged/guides">Guides</a></li>
            <li><a href="/blogs/news/tagged/inspiration">Inspiration</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="footer__col">
        <p class="footer__col-title">Legal</p>
        <ul class="footer__links">
          <li><a href="/policies/privacy-policy">Privacy</a></li>
          <li><a href="/policies/terms-of-service">Terms</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text",     "id": "blog_name",  "label": "Blog name",    "default": "The Journal" },
    { "type": "textarea", "id": "tagline",    "label": "Tagline",      "default": "Stories worth reading." },
    { "type": "text",     "id": "instagram",  "label": "Instagram URL" },
    { "type": "text",     "id": "twitter",    "label": "Twitter/X URL" },
    { "type": "text",     "id": "pinterest",  "label": "Pinterest URL" }
  ]
}
{% endschema %}
