<article class="main-article">

  <!-- Hero -->
  <div class="article-hero">
    {% if article.image %}
      <div class="article-hero__img-wrap">
        <img
          src="{{ article.image | image_url: width: 1600 }}"
          alt="{{ article.image.alt | default: article.title }}"
          loading="eager"
          class="article-hero__img"
        >
      </div>
    {% endif %}
    <div class="article-hero__content page-width">
      {% if article.tags.size > 0 %}
        <div class="article-hero__tags">
          {% for tag in article.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}
      <h1 class="article-hero__title">{{ article.title }}</h1>
      <div class="article-hero__meta">
        <span class="article-meta__author">By {{ article.author }}</span>
        <span class="meta-dot">·</span>
        <span>{{ article.published_at | date: '%B %d, %Y' }}</span>
        <span class="meta-dot">·</span>
        <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="article-body page-width">
    <div class="article-content rte">
      {{ article.content }}
    </div>

    <!-- Tags -->
    {% if article.tags.size > 0 %}
      <div class="article-footer-tags">
        <span>Filed under:</span>
        {% for tag in article.tags %}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="article-tag">{{ tag }}</a>
        {% endfor %}
      </div>
    {% endif %}

    <!-- Author bio -->
    <div class="article-author-card">
      <div class="article-author-card__avatar">
        {{ article.author | slice: 0 }}
      </div>
      <div>
        <p class="article-author-card__name">{{ article.author }}</p>
        <p class="article-author-card__bio">Written for {{ shop.name }}</p>
      </div>
    </div>

    <!-- Share -->
    <div class="article-share">
      <span>Share this story:</span>
      <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}" target="_blank" rel="noopener" class="share-link">Twitter</a>
      <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" class="share-link">Facebook</a>
      <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ article.url }}&description={{ article.title | url_encode }}" target="_blank" rel="noopener" class="share-link">Pinterest</a>
    </div>
  </div>

  <!-- Related articles -->
  {% assign related_count = 0 %}
  {% for a in blog.articles %}
    {% if a.id != article.id and related_count < 3 %}
      {% assign related_count = related_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  {% if related_count > 0 %}
    <div class="related-articles page-width">
      <h3 class="related-articles__heading">More to Read</h3>
      <div class="article-grid article-grid--3">
        {% assign shown = 0 %}
        {% for a in blog.articles %}
          {% if a.id != article.id and shown < 3 %}
            {% assign shown = shown | plus: 1 %}
            {% render 'article-card', article: a, blog: blog %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <!-- Comments -->
  {% if blog.comments_enabled? %}
    <div class="article-comments page-width">
      {% if article.comments_count > 0 %}
        <h3 class="article-comments__heading">{{ article.comments_count }} Comment{{ article.comments_count | pluralize: '', 's' }}</h3>
        {% for comment in article.comments %}
          <div class="comment">
            <p class="comment__author">{{ comment.author }} <span>· {{ comment.created_at | date: '%b %d, %Y' }}</span></p>
            <div class="comment__body">{{ comment.content }}</div>
          </div>
        {% endfor %}
      {% endif %}

      {% form 'new_comment', article %}
        <h3 class="article-comments__heading">Leave a comment</h3>
        {% if form.posted_successfully? %}
          <p class="form-success">Your comment has been submitted for review.</p>
        {% endif %}
        {% if form.errors %}
          <p class="form-error">{{ form.errors | default_errors }}</p>
        {% endif %}
        <div class="comment-form">
          <div class="comment-form__row">
            <input type="text"  name="comment[author]" placeholder="Your name"  class="form-input" required>
            <input type="email" name="comment[email]"  placeholder="Your email" class="form-input" required>
          </div>
          <textarea name="comment[body]" placeholder="Share your thoughts..." rows="5" class="form-input form-textarea" required></textarea>
          <button type="submit" class="btn btn--primary">Post Comment</button>
        </div>
      {% endform %}
    </div>
  {% endif %}

</article>
