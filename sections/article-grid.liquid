{% assign blog = blogs[section.settings.blog] %}

<section class="article-grid-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="section-heading">
        <h2>{{ section.settings.heading }}</h2>
        {% if section.settings.view_all_label != blank %}
          <a href="{{ blog.url }}" class="section-heading__link">{{ section.settings.view_all_label }} →</a>
        {% endif %}
      </div>
    {% endif %}
    <div class="article-grid">
      {% for article in blog.articles limit: section.settings.article_limit %}
        {% render 'article-card', article: article, blog: blog %}
      {% else %}
        <p class="article-grid__empty">No articles yet. Check back soon.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Article Grid",
  "settings": [
    { "type": "blog", "id": "blog", "label": "Blog" },
    { "type": "text", "id": "heading", "label": "Section heading", "default": "Latest Stories" },
    { "type": "text", "id": "view_all_label", "label": "View all link text", "default": "View all" },
    { "type": "range", "id": "article_limit", "label": "Number of articles", "min": 3, "max": 12, "step": 3, "default": 6 }
  ],
  "presets": [{ "name": "Article Grid" }]
}
{% endschema %}