{% assign blog = blogs[section.settings.blog] %}
{% assign featured = blog.articles.first %}
{% if featured %}
<section class="hero-feature">
  <div class="page-width">
    <div class="hero-feature__inner">
      <div class="hero-feature__img-wrap">
        {% if featured.image %}
          <img src="{{ featured.image | image_url: width: 1400 }}" alt="{{ featured.image.alt | default: featured.title }}" loading="eager" class="hero-feature__img">
        {% else %}
          <img src="https://picsum.photos/seed/{{ featured.id }}/1400/900" alt="{{ featured.title }}" loading="eager" class="hero-feature__img">
        {% endif %}
      </div>
      <div class="hero-feature__body">
        {% if featured.tags.size > 0 %}
          <a href="{{ blog.url }}/tagged/{{ featured.tags.first | handle }}" class="hero-feature__tag">{{ featured.tags.first }}</a>
        {% else %}
          <span class="hero-feature__tag">{{ section.settings.label | default: 'Featured Story' }}</span>
        {% endif %}
        <h2 class="hero-feature__title">
          <a href="{{ featured.url }}">{{ featured.title }}</a>
        </h2>
        <p class="hero-feature__excerpt">{{ featured.excerpt_or_content | strip_html | truncatewords: 35 }}</p>
        <div class="hero-feature__meta">
          <span>By {{ featured.author }}</span>
          <span class="meta-dot">·</span>
          <span>{{ featured.published_at | date: '%B %d, %Y' }}</span>
          <span class="meta-dot">·</span>
          <span>{{ featured.content | strip_html | split: ' ' | size | divided_by: 200 | plus: 1 }} min read</span>
        </div>
        <a href="{{ featured.url }}" class="hero-feature__cta">Read Article →</a>
      </div>
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Featured Article",
  "settings": [
    { "type": "blog", "id": "blog",  "label": "Blog" },
    { "type": "text", "id": "label", "label": "Fallback label", "default": "Featured Story" }
  ]
}
{% endschema %}
