<article class="article-card">
  <a href="{{ article.url }}" class="article-card__img-link">
    <div class="article-card__img-wrap">
      {% if article.image %}
        <img
          src="{{ article.image | image_url: width: 800 }}"
          alt="{{ article.image.alt | default: article.title }}"
          loading="lazy"
          class="article-card__img"
        >
      {% else %}
        <img
          src="https://picsum.photos/seed/{{ article.id }}/800/533"
          alt="{{ article.title }}"
          loading="lazy"
          class="article-card__img"
        >
      {% endif %}
    </div>
  </a>
  <div class="article-card__body">
    {% if article.tags.size > 0 %}
      <a href="{{ blog.url }}/tagged/{{ article.tags.first | handle }}" class="article-card__tag">{{ article.tags.first }}</a>
    {% endif %}
    <h3 class="article-card__title">
      <a href="{{ article.url }}">{{ article.title }}</a>
    </h3>
    <p class="article-card__excerpt">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
    <div class="article-card__meta">
      <span>{{ article.author }}</span>
      <span class="meta-dot">·</span>
      <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
    </div>
  </div>
</article>
